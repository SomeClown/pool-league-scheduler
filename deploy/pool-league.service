[Unit]
Description=Pool League Scheduler
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/pool-league-scheduler
Environment="PATH=/opt/pool-league-scheduler/venv/bin"
EnvironmentFile=/opt/pool-league-scheduler/.env
ExecStart=/opt/pool-league-scheduler/venv/bin/gunicorn \
    --config gunicorn.conf.py \
    "run:app"
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
